{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vllm-ascend.local/schemas/deploy_case.schema.json",
  "title": "vLLM Ascend DeployCase",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "doc",
    "requirements",
    "runtime",
    "services",
    "checks",
    "tests"
  ],
  "properties": {
    "apiVersion": {
      "const": "llm-ci/v1"
    },
    "kind": {
      "const": "DeployCase"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "title", "level", "owner", "description", "tags"],
      "properties": {
        "name": {"type": "string"},
        "title": {"type": "string"},
        "level": {"enum": ["static", "smoke", "nightly", "release", "benchmark"]},
        "owner": {"type": "string"},
        "description": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "requirements": {
      "type": "object",
      "required": ["hardware", "software", "model"],
      "properties": {
        "hardware": {
          "type": "object",
          "required": ["soc", "card_count", "allow_parallel_on_host"],
          "properties": {
            "soc": {"enum": ["A2", "A3", "any"]},
            "card_count": {"type": "integer", "minimum": 1},
            "allow_parallel_on_host": {"type": "boolean"}
          }
        },
        "software": {"type": "object"},
        "model": {"type": "object"}
      }
    },
    "runtime": {
      "type": "object",
      "required": ["image", "workdir", "env", "docker"],
      "properties": {
        "image": {"type": "string"},
        "workdir": {"type": "string"},
        "env": {"type": "object"},
        "docker": {
          "type": "object",
          "required": ["enabled", "image", "network", "shm_size", "mounts"],
          "properties": {
            "enabled": {"const": true},
            "image": {"type": "string"},
            "network": {"const": "host"},
            "ipc": {"type": "string"},
            "shm_size": {"type": "string"},
            "mounts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["source", "target", "mode"],
                "properties": {
                  "source": {"type": "string"},
                  "target": {"type": "string"},
                  "mode": {"enum": ["ro", "rw"]}
                }
              }
            }
          }
        }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "type", "host", "port", "log_file", "vllm"]
      }
    }
  }
}
