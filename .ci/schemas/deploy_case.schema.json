{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vllm-ascend.local/schemas/deploy_case.schema.json",
  "title": "vLLM Ascend DeployCase",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "doc",
    "requirements",
    "runtime",
    "services",
    "checks",
    "tests"
  ],
  "properties": {
    "apiVersion": {
      "const": "llm-ci/v1"
    },
    "kind": {
      "const": "DeployCase"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "title", "level", "owner", "description", "tags"],
      "properties": {
        "name": {"type": "string"},
        "title": {"type": "string"},
        "level": {"enum": ["static", "smoke", "nightly", "release", "benchmark"]},
        "levels": {
          "type": "array",
          "items": {"enum": ["static", "smoke", "nightly", "release", "benchmark"]},
          "uniqueItems": true
        },
        "owner": {"type": "string"},
        "description": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "requirements": {
      "type": "object",
      "required": ["hardware", "software", "model"],
      "properties": {
        "hardware": {
          "type": "object",
          "required": ["soc", "card_count", "allow_parallel_on_host"],
          "properties": {
            "soc": {"enum": ["A2", "A3", "any"]},
            "card_count": {"type": "integer", "minimum": 1},
            "allow_parallel_on_host": {"type": "boolean"}
          }
        },
        "software": {"type": "object"},
        "model": {"type": "object"}
      }
    },
    "runtime": {
      "type": "object",
      "required": ["image", "workdir", "env", "docker"],
      "properties": {
        "image": {"type": "string"},
        "workdir": {"type": "string"},
        "env": {"type": "object"},
        "docker": {
          "type": "object",
          "required": ["enabled", "image", "workspace", "network", "shm_size", "mounts"],
          "properties": {
            "enabled": {"const": true},
            "image": {"type": "string"},
            "workspace": {"const": "/home/ma-user/AscendCloud/jenkins"},
            "network": {"const": "host"},
            "ipc": {"type": "string"},
            "shm_size": {"type": "string"},
            "mounts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["source", "target", "mode"],
                "properties": {
                  "source": {"type": "string"},
                  "target": {"type": "string"},
                  "mode": {"enum": ["ro", "rw"]}
                }
              }
            }
          }
        }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "type", "host", "port", "log_file"],
        "properties": {
          "name": {"type": "string"},
          "role": {"type": "string"},
          "type": {"enum": ["vllm-serve", "command"]},
          "host": {"type": "string"},
          "port": {"type": "integer"},
          "log_file": {"type": "string"},
          "served_model_name": {"type": "string"},
          "resources": {
            "type": "object",
            "properties": {
              "card_count": {"type": "integer", "minimum": 0},
              "extra_port_count": {"type": "integer", "minimum": 0},
              "extra_ports": {
                "type": "array",
                "items": {"type": "integer", "minimum": 1, "maximum": 65535}
              }
            }
          },
          "command": {
            "type": "array",
            "items": {"type": "string"}
          },
          "vllm": {"type": "object"}
        }
      }
    },
    "tests": {
      "type": "object",
      "required": ["smoke", "benchmark", "accuracy"],
      "properties": {
        "smoke": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {"type": "boolean"},
            "suites": {
              "type": "object",
              "properties": {
                "include_common": {"type": "boolean"},
                "capabilities": {"type": "array", "items": {"type": "string"}},
                "extra_suite_files": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        },
        "benchmark": {"type": "object"},
        "accuracy": {"type": "object"}
      }
    }
  }
}
