{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vllm-ascend.local/schemas/deploy_case.schema.json",
  "title": "vLLM Ascend DeployCase",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "doc",
    "requirements",
    "runtime",
    "services",
    "checks",
    "tests"
  ],
  "properties": {
    "apiVersion": {
      "const": "llm-ci/v1"
    },
    "kind": {
      "const": "DeployCase"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "title", "level", "owner", "description", "tags"],
      "properties": {
        "name": {"type": "string"},
        "title": {"type": "string"},
        "level": {"enum": ["static", "smoke", "nightly", "release", "benchmark"]},
        "owner": {"type": "string"},
        "description": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "type", "host", "port", "log_file", "vllm"]
      }
    }
  }
}
