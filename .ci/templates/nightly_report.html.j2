<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>vLLM Ascend DeployCase Nightly Report</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 24px; color: #1f2937; }
    h1, h2 { margin-bottom: 8px; }
    table { border-collapse: collapse; width: 100%; margin: 16px 0 28px; }
    th, td { border: 1px solid #d1d5db; padding: 8px; text-align: left; vertical-align: top; }
    th { background: #f3f4f6; }
    .passed { color: #047857; font-weight: 600; }
    .failed { color: #b91c1c; font-weight: 600; }
    .skipped { color: #6b7280; font-weight: 600; }
    .summary { display: flex; gap: 12px; margin: 16px 0 28px; }
    .metric { border: 1px solid #d1d5db; padding: 12px 16px; min-width: 120px; }
    code { white-space: pre-wrap; }
  </style>
</head>
<body>
  <h1>vLLM Ascend DeployCase Nightly Report</h1>
  <p>Generated at {{ generated_at }}</p>

  <div class="summary">
    <div class="metric">Total<br><strong>{{ total }}</strong></div>
    <div class="metric">Passed<br><strong class="passed">{{ passed }}</strong></div>
    <div class="metric">Failed<br><strong class="failed">{{ failed }}</strong></div>
    <div class="metric">Skipped<br><strong class="skipped">{{ skipped }}</strong></div>
  </div>

  <h2>Cases</h2>
  <table>
    <thead>
      <tr>
        <th>Case</th>
        <th>Level</th>
        <th>Status</th>
        <th>Failure Stage</th>
        <th>Failure Reason</th>
        <th>Server Log</th>
      </tr>
    </thead>
    <tbody>
      {{ case_rows }}
    </tbody>
  </table>

  <h2>Benchmark</h2>
  <table>
    <thead>
      <tr><th>Case</th><th>Status</th><th>Metrics</th><th>Log</th></tr>
    </thead>
    <tbody>
      {{ benchmark_rows }}
    </tbody>
  </table>

  <h2>Accuracy</h2>
  <table>
    <thead>
      <tr><th>Case</th><th>Status</th><th>Mode</th><th>Score</th></tr>
    </thead>
    <tbody>
      {{ accuracy_rows }}
    </tbody>
  </table>

  <h2>Environment</h2>
  <pre><code>{{ environment_json }}</code></pre>
</body>
</html>
